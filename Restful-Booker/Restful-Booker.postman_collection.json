          "name": "Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response body as JSON\r",
                  "var responseBody = pm.response.json();\r",
                  "\r",
                  "// Save the token to the environment variable for use in future requests\r",
                  "pm.environment.set(\"token\", responseBody.token);\r",
                  "\r",
                  "// Check that the request was successful\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Check that a token was actually returned in the response\r",
                  "pm.test(\"Token is present in response\", () => {\r",
                  "    pm.expect(responseBody.token).to.exist;\r",
                  "});\r",
                  "\r",
                  "// Check response time\r",
                  "pm.test(\"Response time is less than 2000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
                ],
                "type": "text/javascript",
