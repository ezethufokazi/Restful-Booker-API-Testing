              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response body as JSON\r",
                  "var responseBody = pm.response.json();\r",
                  "\r",
                  "// Save the bookingId in the environment variables for future use\r",
                  "pm.environment.set(\"bookingId\", responseBody.bookingid);\r",
                  "\r",
                  "// Save the booking details in environment variables for future use\r",
                  "pm.environment.set(\"firstName\", responseBody.booking.firstname);\r",
                  "pm.environment.set(\"lastName\", responseBody.booking.lastname);\r",
                  "pm.environment.set(\"totalPrice\", responseBody.booking.totalprice);\r",
                  "pm.environment.set(\"depositPaid\", responseBody.booking.depositpaid);\r",
                  "pm.environment.set(\"checkin\", responseBody.booking.bookingdates.checkin);\r",
                  "pm.environment.set(\"checkout\", responseBody.booking.bookingdates.checkout);\r",
                  "pm.environment.set(\"additionalNeeds\", responseBody.booking.additionalneeds);\r",
                  "\r",
                  "// Check request was successful\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Check booking ID is present in response\r",
                  "pm.test(\"Booking ID is present\", () => {\r",
                  "    pm.expect(responseBody.bookingid).to.exist;\r",
                  "});\r",
                  "\r",
                  "// Check first name is correct\r",
                  "pm.test(\"First name is correct\", () => {\r",
                  "    pm.expect(responseBody.booking.firstname).to.eql(pm.environment.get(\"firstName\"));\r",
                  "});\r",
                  "\r",
                  "// Check last name is correct\r",
                  "pm.test(\"Last name is correct\", () => {\r",
                  "    pm.expect(responseBody.booking.lastname).to.eql(pm.environment.get(\"lastName\"));\r",
                  "});\r",
                  "\r",
                  "// Check response time\r",
                  "pm.test(\"Response time is less than 2000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});"
